GEMINI_API_KEY=your_gemini_api_key_here

# Manifest backend: local (Phase 1) or dynamodb (Phase 2)
MANIFEST_BACKEND=local

# AWS (Phase 2 only)
AWS_REGION=eu-north-1
MANIFEST_TABLE=fossilrag-manifest
ENRICHMENT_TABLE=fossilrag-enrichment

# Paths (local Phase 1)
RAW_DIR=data/raw
SILVER_DIR=data/silver
GOLD_DIR=data/gold
INDEX_DIR=data/index
CACHE_DIR=data/cache
